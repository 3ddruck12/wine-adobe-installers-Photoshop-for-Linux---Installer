+HRESULT set_node_event_handler_by_attr(HTMLDOMNode *node, const WCHAR *name, VARIANT *var)
+{
+    eventid_t eid;
+
+    eid = attr_to_eid(name);
+    if(eid == EVENTID_LAST)
+        return S_FALSE;
+
+    if(V_VT(var) == VT_BSTR && node->doc->window) {
+        IDispatch *disp = script_parse_event(node->doc->window, V_BSTR(var));
+        if(disp) {
+            VARIANT v;
+            HRESULT hres;
+
+            V_VT(&v) = VT_DISPATCH;
+            V_DISPATCH(&v) = disp;
+            hres = set_node_event(node, eid, &v);
+            IDispatch_Release(disp);
+            return hres;
+        }
+    }
+
+    return set_node_event(node, eid, var);
+}
